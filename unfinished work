#include <iostream>
#include <string>
using namespace std;

struct Product {
    string name;
    int quantity;
    float price;
};

int main() {
    Product p[5];
    int max;
    
    cout << "How many products only a maximum of 5: ";
    cin >> max;
    
    for (int i = 0; i < max; i++) {
        cout << "Enter Product Name: ";
        cin >> p[i].name;
        
        cout << "Enter your Quantity: ";
        cin >> p[i].quantity;
        
        cout << "Enter the Price: ";
        cin >> p[i].price;
        
        cout << endl;
    }   
        
    cout << "LIST OF PRODUCTS\n";
    for (int i = 0; i < max; i++) {
        cout << "Name: " << p[i].name << " Quantity: " << p[i].quantity << " Price: " << p[i].price << endl;
        cout << "Total Value: " << (p[i].quantity * p[i].price) << endl;
        
    }
    
    int maxValue = 0
    for (int i = 0; i < max; i++) {
        if (p[i.price] > p[maxValue].name) {
            maxValue = i;
        }
        cout << p[maxValue].name << " Is the most expensive value" << " with a price of " << p[maxValue].price << endl;
        
    }
    
    return 0;
}
