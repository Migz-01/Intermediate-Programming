#include <iostream>
#include <ctime>
using namespace std;

string adminPass = "6767";

int denominations[] = {500, 1000, 5000};
int bills[] = {10, 10, 10};

string card[20];
string pin[20];
string bank[20];
string type[20];
double balance[20];
int accountCount = 0;

void viewCash() {
    int total = 0;
    cout << "\n=== CURRENT ATM CASH ===\n";
    for(int i=0; i<3; i++){
        cout << "PHP " << denominations[i] << " : " << bills[i] << " bills\n";
        total += denominations[i] * bills[i];
    }
    cout << "Total Cash Available: PHP " << total << endl;
}

void refillCash(int denom[], int billCount[]) {
    time_t now = time(0);
    tm* localTime = localtime(&now);

    if (localTime->tm_hour != 8 || localTime->tm_min > 15) {
        cout << "Refill allowed only from 8:00 AM to 8:15 AM." << endl;
        return;
    }

    billCount[0] += 50;
    cout << "Refill successful." << endl;
}

void createAccount(){

    cout << "Enter Card Number: ";
    cin >> card[accountCount];
    cout << "Enter PIN: ";
    cin >> pin[accountCount];
    cout << "Enter Bank: ";
    cin >> bank[accountCount];
    cout << "Enter Account Type: ";
    cin >> type[accountCount];
    cout << "Enter Balance: ";
    cin >> balance[accountCount];

    accountCount++;
    cout << "Account Created\n";
}

void viewAccounts(){
    cout << "\n=== ALL ACCOUNTS ===\n";
    for(int i=0;i<accountCount;i++){
        cout << "Card: " << card[i];
        cout << "Bank: " << bank[i];
        cout << "Type: " << type[i];
        cout << "Balance: " << balance[i];
        cout << endl;
    }
}

void deleteAccount(){
    string search;
    cout << "Enter card number to delete: ";
    cin >> search;

    for(int i=0;i<accountCount;i++){
        if(card[i] == search){
            for(int j=i;j<accountCount-1;j++){
                card[j] = card[j+1];
                pin[j] = pin[j+1];
                bank[j] = bank[j+1];
                type[j] = type[j+1];
                balance[j] = balance[j+1];
            }

            accountCount--;
            cout << "Account Deleted\n";
            return;
        }
    }
    cout << "Account Not Found\n";
}

void resetPIN(){
    string search;
    cout << "Enter card number: ";
    cin >> search;

    for(int i=0;i<accountCount;i++){
        if(card[i] == search){
            cout << "Enter new PIN: ";
            cin >> pin[i];
            cout << "PIN Reset Successful\n";
            return;
        }
    }

    cout << "Account Not Found\n";
}

void changeAdminPass(){

    string current;

    cout << "Enter current passcode: ";
    cin >> current;

    if(current == adminPass){

        cout << "Enter new passcode: ";
        cin >> adminPass;

        cout << "Passcode Changed\n";
    }
    else{
        cout << "Incorrect Passcode\n";
    }
}

