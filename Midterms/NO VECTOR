void adminMenu(){
    int choice;
    do{
        cout << "\n===== ADMIN MENU =====\n";
        cout << "1 View Cash\n";
        cout << "2 Refill Cash\n";
        cout << "3 Create Account\n";
        cout << "4 View Accounts\n";
        cout << "5 Delete Account\n";
        cout << "6 Reset PIN\n";
        cout << "7 Change Admin Passcode\n";
        cout << "8 View Admin Users\n";
        cout << "9 Exit\n";
        cout << "Choice: ";
        cin >> choice;

        switch(choice){
            case 1: viewCash(); break;
            case 2: refillCash(denominations, bills); break;
            case 3: createAccount(); break;
            case 4: viewAccounts(); break;
            case 5: deleteAccount(); break;
            case 6: resetPIN(); break;
            case 7: changeAdminPass(); break;
            case 8: viewAdmins(); break;
        }
    }while(choice != 9);
}

bool adminLogin(){
    string input;
    int attempts = 0;

    while(attempts < 3){
        cout << "Enter Admin Passcode: ";
        cin >> input;
        if(input == adminPass){
            cout << "Login Successful\n";
            return true;
        }
        attempts++;
        cout << "Wrong Passcode\n";
    }
    cout << "System Locked\n";
    return false;
}

int main() {
    if(adminLogin()){
        adminMenu();
    }
    return 0;
}
