bool adminLogin() {
    string input;
    int attempts = 0;

    while (attempts < 3) {
        cout << "Enter Admin Passcode: "; 
        cin >> input;
        if (input == adminPass) {
            cout << "Login Successful\n";
            return true;
        }
        attempts++;
        cout << "Wrong Passcode\n";
    }
    cout << "System Locked\n";
    return false;
}

