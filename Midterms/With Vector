void viewAccounts() {
    cout << "\n=== ALL ACCOUNTS ===\n";
    for (int i = 0; i < accountCount; i++) {
        cout << "Card: " << card[i];
        cout << " | Bank: " << bank[i];
        cout << " | Type: " << type[i];
        cout << " | Balance: " << balance[i] << endl;
    }
}

void deleteAccount() {
    string search;
    cout << "Enter card number to delete: "; 
    cin >> search;

    vector<string> vCard(card, card + accountCount);
    vector<string> vPin(pin, pin + accountCount);
    vector<string> vBank(bank, bank + accountCount);
    vector<string> vType(type, type + accountCount);
    vector<double> vBalance(balance, balance + accountCount);

    for (int i = 0; i < vCard.size(); i++) {
        if (vCard[i] == search) {
            vCard.erase(vCard.begin() + i);
            vPin.erase(vPin.begin() + i);
            vBank.erase(vBank.begin() + i);
            vType.erase(vType.begin() + i);
            vBalance.erase(vBalance.begin() + i);

            for (int j = 0; j < vCard.size(); j++) {
                card[j] = vCard[j];
                pin[j] = vPin[j];
                bank[j] = vBank[j];
                type[j] = vType[j];
                balance[j] = vBalance[j];
            }

            accountCount--;
            cout << "Account Deleted\n";
            return;
        }
    }
    cout << "Account Not Found\n";
}

void resetPIN() {
    string search;
    cout << "Enter card number: "; cin >> search;

    for (int i = 0; i < accountCount; i++) {
        if (card[i] == search) {
            cout << "Enter new PIN: "; cin >> pin[i];
            cout << "PIN Reset Successful\n";
            return;
        }
    }
    cout << "Account Not Found\n";
}

