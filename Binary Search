#include <iostream>
using namespace std;

int main()
{
    int arr[5] = {10, 20, 30, 40, 50};

    int target = 40;

    int left = 0;
    int right = 4;

    bool found = false;

    while(left <= right)
    {
        int mid = (left + right) / 2;

        if(arr[mid] == target)
        {
            cout << "Found at index: " << mid;
            found = true;
            break;
        }
        else if(arr[mid] < target)
        {
            left = mid + 1;
        }
        else
        {
            right = mid - 1;
        }
    }

    if(!found)
    {
        cout << "Not Found";
    }

    return 0;
}
